---
interface Action {
  label: string;
  href: string;
  variant: 'primary' | 'secondary' | 'tertiary';
}

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  actions: Action[];
}

const { eyebrow, title, description, actions } = Astro.props;
const variantClass = {
  primary: 'button-primary',
  secondary: 'button-secondary',
  tertiary: 'button-tertiary',
};
---

<section class="section-space bg-moss/30">
  <div class="page-shell">
    <div class="p-8 sm:p-10 lg:p-12">
      <p class="eyebrow mb-4">{eyebrow}</p>
      <div class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
        <div>
          <h2 class="text-3xl font-semibold leading-tight sm:text-4xl">{title}</h2>
          <p class="mt-4 max-w-2xl">{description}</p>
        </div>
        <div class="flex flex-wrap gap-3 lg:justify-end">
          {actions.map((action) => (
            <a href={action.href} class={variantClass[action.variant]}>
              {action.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
