---
import navigation from '../data/navigation.json';
import site from '../data/site.json';
import { safeHref } from '../utils/safeHref';

function normalizePath(path) {
  if (!path) return '/';
  return path.length > 1 ? path.replace(/\/+$/, '') : path;
}

const currentPath = normalizePath(Astro.url.pathname);
---

<header class="sticky top-0 z-40 border-b border-line/90 bg-parchment/95 backdrop-blur">
  <div class="page-shell flex min-h-[5rem] items-center justify-between gap-6">
    <a href="/" class="min-w-0 flex-1 text-left" aria-label={`${site.labName} home`}>
      <p class="eyebrow mb-1 text-sage">COLPOS | Crop Physiology Research</p>
      <div class="font-serif text-xl font-semibold text-forest sm:text-2xl">{site.labName}</div>
    </a>

    <nav class="hidden items-center gap-1 lg:flex" aria-label="Primary">
      {navigation.main.map((item) => (
        (() => {
          const href = safeHref(item.href);
          const isActive = currentPath === normalizePath(href);
          return (
        <a
          href={href}
          class:list={[
            'rounded-full px-3 py-2 text-sm font-semibold transition duration-300 ease-calm',
            isActive ? 'bg-soft text-forest' : 'text-muted hover:text-pine',
          ]}
          aria-current={isActive ? 'page' : undefined}
        >
          {item.label}
        </a>
          );
        })()
      ))}
    </nav>

    <details class="group lg:hidden">
      <summary
        class="inline-flex h-11 w-11 list-none items-center justify-center rounded-full border border-line bg-white text-forest transition hover:border-pine hover:text-pine [&::-webkit-details-marker]:hidden"
        aria-label="Toggle navigation menu"
      >
        <span class="relative block h-4 w-5">
          <span class="absolute left-0 top-0 h-0.5 w-5 bg-current transition group-open:translate-y-[7px] group-open:rotate-45"></span>
          <span class="absolute left-0 top-[7px] h-0.5 w-5 bg-current transition group-open:opacity-0"></span>
          <span class="absolute left-0 top-[14px] h-0.5 w-5 bg-current transition group-open:-translate-y-[7px] group-open:-rotate-45"></span>
        </span>
      </summary>
      <div class="absolute left-0 right-0 top-full max-h-0 overflow-hidden border-b border-line bg-parchment opacity-0 transition-all duration-300 ease-calm group-open:max-h-[32rem] group-open:opacity-100">
        <nav class="page-shell flex flex-col gap-2 py-4" aria-label="Mobile">
          {navigation.main.map((item) => (
            (() => {
              const href = safeHref(item.href);
              const isActive = currentPath === normalizePath(href);
              return (
            <a
              href={href}
              class:list={[
                'rounded-2xl border px-4 py-3 text-base font-semibold transition',
                isActive
                  ? 'border-pine bg-soft text-forest'
                  : 'border-transparent bg-white text-muted hover:border-line hover:text-pine',
              ]}
              aria-current={isActive ? 'page' : undefined}
            >
              {item.label}
            </a>
              );
            })()
          ))}
        </nav>
      </div>
    </details>
  </div>
</header>
