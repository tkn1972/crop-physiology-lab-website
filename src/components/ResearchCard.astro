---
interface Area {
  title: string;
  summary: string;
  description: string;
  methods: string[];
  tools: string[];
  outputs: string[];
  relatedPublications: string[];
}

const { area } = Astro.props as { area: Area };
---

<details class="group border-b border-line pb-8 mb-8">
  <summary class="flex cursor-pointer list-none flex-col gap-4 p-6 text-left sm:p-8">
    <div class="flex items-start justify-between gap-4">
      <div>
        <p class="eyebrow mb-3">Research Area</p>
        <h3 class="text-2xl font-semibold">{area.title}</h3>
      </div>
      <span class="font-mono text-xs uppercase tracking-[0.2em] text-pine">
        <span class="group-open:hidden">Expand</span>
        <span class="hidden group-open:inline">Collapse</span>
      </span>
    </div>
    <p>{area.summary}</p>
    <div class="flex flex-wrap gap-2">
      {area.methods.slice(0, 4).map((method) => (
        <span class="rounded-full bg-soft px-3 py-1 font-mono text-xs uppercase tracking-[0.16em] text-forest">
          {method}
        </span>
      ))}
    </div>
  </summary>

  <div class="border-t border-line px-6 py-6 sm:px-8">
    <p>{area.description}</p>
    <div class="mt-6 grid gap-6 lg:grid-cols-3">
      <div>
        <h4 class="font-mono text-xs uppercase tracking-[0.22em] text-forest">Tools</h4>
        <ul class="mt-3 space-y-2 text-muted">
          {area.tools.map((tool) => <li>{tool}</li>)}
        </ul>
      </div>
      <div>
        <h4 class="font-mono text-xs uppercase tracking-[0.22em] text-forest">Outputs</h4>
        <ul class="mt-3 space-y-2 text-muted">
          {area.outputs.map((output) => <li>{output}</li>)}
        </ul>
      </div>
      <div>
        <h4 class="font-mono text-xs uppercase tracking-[0.22em] text-forest">Related Publications</h4>
        <ul class="mt-3 space-y-2 text-muted">
          {area.relatedPublications.map((publication) => <li>{publication}</li>)}
        </ul>
      </div>
    </div>
  </div>
</details>
