---
interface Resource {
  title: string;
  category: string;
  description: string;
  format: string;
  status: string;
  actionLabel: string;
}

const { resource } = Astro.props as { resource: Resource };

const statusTone = {
  Public: 'bg-[#e7f1e8] text-pine',
  Draft: 'bg-[#f7efe0] text-earth',
  Internal: 'bg-[#efe9e4] text-charcoal',
  Updated: 'bg-[#eaf0e9] text-pine',
};
---

<article
  class="resource-card surface-card flex h-full flex-col p-6"
  data-category={resource.category}
>
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="font-mono text-xs uppercase tracking-[0.22em] text-muted">{resource.category}</p>
      <h3 class="mt-3 text-xl font-semibold">{resource.title}</h3>
    </div>
    <span
      class:list={[
        'rounded-full px-3 py-1 font-mono text-xs uppercase tracking-[0.16em]',
        statusTone[resource.status as keyof typeof statusTone] || 'bg-soft text-charcoal',
      ]}
    >
      {resource.status}
    </span>
  </div>

  <p class="mt-4">{resource.description}</p>
  <div class="mt-6 flex items-center justify-between gap-3">
    <span class="font-mono text-xs uppercase tracking-[0.2em] text-muted">{resource.format}</span>
    <button type="button" class="button-secondary">{resource.actionLabel}</button>
  </div>
</article>
