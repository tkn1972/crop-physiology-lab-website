---
import ResourceCard from './ResourceCard.astro';
import resources from '../data/resources.json';

const categories = ['All', ...new Set(resources.map((resource) => resource.category))];
---

<section class="section-space" data-resource-library>
  <div class="page-shell">
    <div class="max-w-3xl">
      <p class="eyebrow mb-3">Resource Library</p>
      <h2 class="text-3xl font-semibold leading-tight sm:text-4xl">Client-side search and category filtering</h2>
      <p class="mt-4">
        Use the live search and filters below to locate documents relevant to analytical workflows, design planning, and student training.
      </p>
    </div>

    <div class="mt-8 grid gap-4 lg:grid-cols-[1.15fr_1fr] lg:items-end" data-resource-controls>
      <label class="block">
        <span class="sr-only">Search resources by title, category, format, or status</span>
        <input
          type="search"
          placeholder="Search resources by title, category, format, or status"
          class="w-full rounded-full border border-line bg-white px-5 py-3 text-base text-charcoal placeholder:text-muted"
          data-resource-search
        />
      </label>

      <div>
        <p class="mb-3 font-mono text-xs uppercase tracking-[0.22em] text-muted">Category</p>
        <div class="flex flex-wrap gap-2">
          {categories.map((category, index) => (
            <button
              type="button"
              class:list={[
                'rounded-full border px-4 py-2 text-sm font-semibold transition',
                index === 0
                  ? 'border-pine bg-soft text-charcoal'
                  : 'border-line bg-white text-muted hover:border-pine hover:text-pine',
              ]}
              data-resource-filter={category}
              aria-pressed={index === 0 ? 'true' : 'false'}
            >
              {category}
            </button>
          ))}
        </div>
      </div>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-3" data-resource-grid>
      {resources.map((resource) => <ResourceCard resource={resource} />)}
    </div>

    <div class="surface-card mt-10 hidden p-10 text-center" data-resource-empty>
      <h3 class="text-2xl font-semibold">No resources match the current filters</h3>
      <p class="mt-4">Try a broader search term or switch back to the <strong>All</strong> category.</p>
    </div>
  </div>
</section>

<script>
  const root = document.querySelector('[data-resource-library]');
  const searchInput = root?.querySelector('[data-resource-search]');
  const controls = root?.querySelector('[data-resource-controls]');
  const filterButtons = Array.from(root?.querySelectorAll('[data-resource-filter]') || []);
  const resourceCards = Array.from(root?.querySelectorAll('.resource-card') || []);
  const emptyState = root?.querySelector('[data-resource-empty]');

  if (root && searchInput && controls && filterButtons.length && resourceCards.length && emptyState) {
    let activeCategory = 'All';
    const resourceEntries = resourceCards.map((card) => ({
      card,
      category: card.getAttribute('data-category') || '',
      searchable: (card.textContent || '').toLowerCase(),
    }));

    const update = () => {
      const query = searchInput.value.toLowerCase().trim();
      let visibleCount = 0;

      resourceEntries.forEach(({ card, category, searchable }) => {
        const matchesCategory = activeCategory === 'All' || category === activeCategory;
        const matchesQuery = !query || searchable.includes(query);
        const visible = matchesCategory && matchesQuery;
        card.classList.toggle('hidden', !visible);
        if (visible) visibleCount += 1;
      });

      emptyState.classList.toggle('hidden', visibleCount !== 0);
    };

    controls.addEventListener('click', (event) => {
      const button = event.target instanceof HTMLElement ? event.target.closest('[data-resource-filter]') : null;
      if (!button) {
        return;
      }

      if (button instanceof HTMLElement) {
        activeCategory = button.getAttribute('data-resource-filter') || 'All';
        filterButtons.forEach((candidate) => {
          const isActive = candidate === button;
          candidate.setAttribute('aria-pressed', String(isActive));
          candidate.classList.toggle('border-pine', isActive);
          candidate.classList.toggle('bg-soft', isActive);
          candidate.classList.toggle('text-charcoal', isActive);
          candidate.classList.toggle('border-line', !isActive);
          candidate.classList.toggle('bg-white', !isActive);
          candidate.classList.toggle('text-muted', !isActive);
        });
        update();
      }
    });

    searchInput.addEventListener('input', update);
    update();
  }
</script>
