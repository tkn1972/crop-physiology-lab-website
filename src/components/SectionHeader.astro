---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, description, align = 'left' } = Astro.props;
const alignment = align === 'center' ? 'mx-auto max-w-3xl text-center' : 'max-w-3xl';
---

<div class={alignment}>
  {eyebrow ? <p class="eyebrow mb-3">{eyebrow}</p> : null}
  <h2 class="text-3xl font-semibold leading-tight sm:text-4xl">{title}</h2>
  {description ? <p class="mt-4">{description}</p> : null}
</div>
