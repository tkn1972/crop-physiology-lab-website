---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import PageHero from '../components/PageHero.astro';
import PublicationItem from '../components/PublicationItem.astro';
import site from '../data/site.json';
import research from '../data/research.json';
import publications from '../data/publications.json';
import resources from '../data/resources.json';

const featuredPublications = [...publications].sort((a, b) => b.year - a.year).slice(0, 3);
---

<BaseLayout
  title={`${site.labName} | Home`}
  description="Crop Physiology Lab at Colegio de Postgraduados (COLPOS) — research in plant phenotyping, analytical chemistry, and reproducible experimental design."
>
  <PageHero eyebrow={site.hero.eyebrow} title={site.labName} description={site.hero.description}>
    <div>
      <p class="eyebrow mb-3">Research Identity</p>
      <h2 class="text-3xl font-semibold leading-tight">{site.tagline}</h2>
      <div class="mt-6 flex flex-wrap gap-3">
        {site.hero.ctas.map((cta) => (
          <a
            href={cta.href}
            class={cta.variant === 'primary' ? 'button-primary' : cta.variant === 'secondary' ? 'button-secondary' : 'button-tertiary'}
          >
            {cta.label}
          </a>
        ))}
      </div>
      <img
        src="/images/hero/glasshouse.svg"
        alt="Illustrated greenhouse and plant phenotyping environment"
        class="mt-8 w-full rounded-[1.25rem] border border-line"
      />
    </div>
  </PageHero>

  <section class="section-space bg-cream">
    <div class="page-shell grid gap-10 lg:grid-cols-[0.95fr_1.05fr]">
      <div>
        <div class="max-w-3xl">
          <p class="eyebrow mb-3">About the Lab</p>
          <h2 class="text-3xl font-semibold leading-tight sm:text-4xl">A measurement-centered approach to plant physiology</h2>
          <p class="mt-4">{site.mission}</p>
        </div>
      </div>
      <div class="bg-surface p-8">
        <p class="eyebrow mb-3">Principal Investigator</p>
        <h3 class="text-2xl font-semibold">{site.contact.piName}</h3>
        <p class="mt-4">{site.piBio}</p>
        <div class="mt-6 grid gap-4 border-t border-line pt-6 sm:grid-cols-2">
          <div>
            <p class="font-mono text-xs uppercase tracking-[0.22em] text-muted">Strengths</p>
            <ul class="mt-3 space-y-2 text-muted">
              <li>Controlled-environment experiment design</li>
              <li>Germplasm evaluation and physiology integration</li>
              <li>Chromatographic and metabolite workflows</li>
            </ul>
          </div>
          <div>
            <p class="font-mono text-xs uppercase tracking-[0.22em] text-muted">Location</p>
            <p class="mt-3">{site.institution}</p>
            <p class="mt-2">{site.location}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-space border-y border-line/80 bg-moss-light">
    <div class="page-shell">
      <div class="max-w-3xl">
        <p class="eyebrow mb-3">Research Focus</p>
        <h2 class="text-3xl font-semibold leading-tight sm:text-4xl">Current themes in crop and model plant physiology</h2>
        <p class="mt-4">
          Our projects span method development, mechanistic physiology, and experimental design with an emphasis on transparent inference.
        </p>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        {research.slice(0, 4).map((area) => (
          <article class="flex flex-col p-6">
            <p class="eyebrow mb-3">Theme</p>
            <h3 class="text-2xl font-semibold">{area.title}</h3>
            <p class="mt-4 flex-1">{area.summary}</p>
            <a href="/research" class="mt-6 text-sm font-semibold text-pine transition hover:text-forest">
              View research area
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="page-shell grid gap-12 lg:grid-cols-[1fr_0.92fr]">
      <div>
        <div class="max-w-3xl">
          <p class="eyebrow mb-3">Featured Publications</p>
          <h2 class="text-3xl font-semibold leading-tight sm:text-4xl">Recent work from the lab</h2>
          <p class="mt-4">
            Selected papers highlight our work in quantitative phenotyping, experimental design, and analytical methods.
          </p>
        </div>
        <div class="mt-8 border-t border-line">
          {featuredPublications.map((publication) => <PublicationItem publication={publication} />)}
        </div>
        <a href="/publications" class="mt-6 inline-flex text-sm font-semibold text-pine transition hover:text-forest">
          Browse all publications
        </a>
      </div>

      <div class="bg-surface p-8">
        <div class="max-w-3xl">
          <p class="eyebrow mb-3">Resources Preview</p>
          <h2 class="text-3xl font-semibold leading-tight sm:text-4xl">Protocols, templates, and guides</h2>
          <p class="mt-4">A shared reference library for new students, collaborators, and ongoing project teams.</p>
        </div>
        <div class="mt-8 space-y-4">
          {resources.slice(0, 4).map((resource) => (
            <div class="rounded-2xl border border-line bg-white p-4">
              <div class="flex items-center justify-between gap-3">
                <h3 class="text-lg font-semibold">{resource.title}</h3>
                <span class="font-mono text-xs uppercase tracking-[0.2em] text-muted">{resource.format}</span>
              </div>
              <p class="mt-2 text-sm">{resource.description}</p>
            </div>
          ))}
        </div>
        <a href="/resources" class="mt-6 inline-flex text-sm font-semibold text-pine transition hover:text-forest">
          Explore lab resources
        </a>
      </div>
    </div>
  </section>

  <CTASection
    eyebrow="Collaboration and Recruitment"
    title="We welcome carefully designed collaborations and inquiries from graduate trainees"
    description="The lab works with breeders, physiologists, statisticians, and analytical scientists. We are particularly interested in projects that connect strong experimental design with interpretable plant measurements."
    actions={[
      { label: 'Contact the Lab', href: '/contact', variant: 'primary' },
      { label: 'Student Guidance', href: '/students', variant: 'secondary' },
    ]}
  />
</BaseLayout>
